{
  "name": "elo-mmr-kit",
  "version": "1.0.0",
  "description": "Zero-dependency, fully configurable Elo/MMR rating and matchmaking toolkit for games",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "elo",
    "mmr",
    "matchmaking",
    "rating",
    "ranking",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/node": "^20.11.0",
    "eslint": "^9.7.0",
    "fast-check": "^3.19.0",
    "prettier": "^3.3.3",
    "tsup": "^8.2.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.3"
  }
}
